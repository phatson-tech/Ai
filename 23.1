import folium

# 1. Tạo bản đồ ngay tại UEH (tọa độ cơ sở A)
m = folium.Map(location=[10.7814, 106.6920], zoom_start=15)

# 2. Đánh dấu UEH (màu đỏ)
folium.Marker([10.7814, 106.6920], popup="Trường UEH", icon=folium.Icon(color="red")).add_to(m)

# 3. Đánh dấu 5 điểm công cộng xung quanh (viết từng dòng cho dễ hiểu)
